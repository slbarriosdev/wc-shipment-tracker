msgstr "Вы уверены, что хотите удалить этот номер отслеживания?"

msgid "An error occurred. Please try again."
msgstr "Произошла ошибка. Пожалуйста, попробуйте ещё раз."

msgid "Please enter a tracking number."
msgstr "Пожалуйста, введите номер отслеживания."

msgid "Search provider…"
msgstr "Поиск перевозчика…"

msgid "Edit Tracking"
msgstr "Редактировать отслеживание"

msgid "Shipped on %s"
msgstr "Отправлено %s"

msgid "No shipping date"
msgstr "Дата отправки не указана"

msgid "Track"
msgstr "Отследить"

msgid "Edit"
msgstr "Редактировать"

msgid "Delete"
msgstr "Удалить"

msgid "Tracking number is required."
msgstr "Номер отслеживания обязателен."

msgid "Could not update tracking item."
msgstr "Не удалось обновить отслеживание."

msgid "Could not delete tracking item."
msgstr "Не удалось удалить отслеживание."

msgid "Sorry, you cannot list resources."
msgstr "Извините, у вас нет прав для просмотра ресурсов."

msgid "Sorry, you are not allowed to create resources."
msgstr "Извините, у вас нет прав для создания ресурсов."

msgid "Sorry, you cannot view this resource."
msgstr "Извините, у вас нет прав для просмотра этого ресурса."


msgid "Cannot create existing tracking item."
msgstr "Невозможно создать уже существующее отслеживание."

msgid "The tracking item cannot be deleted."
msgstr "Отслеживание не может быть удалено."

msgid "Unique identifier for the tracking item."
msgstr "Уникальный идентификатор отслеживания."

msgid "Tracking provider name."
msgstr "Название перевозчика."

msgid "Custom provider name."
msgstr "Название пользовательского перевозчика."

msgid "Custom tracking URL."
msgstr "Пользовательский URL отслеживания."


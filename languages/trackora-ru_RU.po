msgid "WC Shipment Tracker requires WooCommerce to be installed and active."
msgstr "WC Shipment Tracker требует установки и активации WooCommerce."

msgid "Shipment Tracking"
msgstr "Отслеживание отправления"

msgid "Add Tracking Number"
msgstr "Добавить номер отслеживания"

msgid "Provider:"
msgstr "Перевозчик:"

msgid "Custom Provider"
msgstr "Пользовательский перевозчик"

msgid "Provider Name:"
msgstr "Название перевозчика:"


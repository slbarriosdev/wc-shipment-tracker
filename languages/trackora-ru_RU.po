msgstr "Отследить"

msgid "Edit"
msgstr "Редактировать"

msgid "Delete"
msgstr "Удалить"

msgid "Tracking number is required."
msgstr "Номер отслеживания обязателен."

msgid "Could not update tracking item."
msgstr "Не удалось обновить отслеживание."

msgid "Could not delete tracking item."
msgstr "Не удалось удалить отслеживание."

msgid "Sorry, you cannot list resources."
msgstr "Извините, у вас нет прав для просмотра ресурсов."

msgid "Sorry, you are not allowed to create resources."
msgstr "Извините, у вас нет прав для создания ресурсов."

msgid "Sorry, you cannot view this resource."
msgstr "Извините, у вас нет прав для просмотра этого ресурса."

msgid "Sorry, you are not allowed to delete this resource."
msgstr "Извините, у вас нет прав для удаления этого ресурса."

msgid "Invalid order ID."
msgstr "Неверный идентификатор заказа."

msgid "Invalid tracking ID."
msgstr "Неверный идентификатор отслеживания."

msgid "Cannot create existing tracking item."
msgstr "Невозможно создать уже существующее отслеживание."

msgid "The tracking item cannot be deleted."
msgstr "Отслеживание не может быть удалено."

msgid "Unique identifier for the tracking item."
msgstr "Уникальный идентификатор отслеживания."

msgid "Tracking provider name."
msgstr "Название перевозчика."


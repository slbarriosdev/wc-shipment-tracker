msgstr "Agregar número de rastreo"

msgid "Provider:"
msgstr "Paquetería:"

msgid "Custom Provider"
msgstr "Paquetería personalizada"

msgid "Provider Name:"
msgstr "Nombre de la paquetería:"

msgid "Tracking Number:"
msgstr "Número de rastreo:"


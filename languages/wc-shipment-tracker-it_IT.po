msgid "Unique identifier for the tracking item."
msgstr "Identificatore univoco del tracciamento."

msgid "Tracking provider name."
msgstr "Nome del corriere."

msgid "Custom provider name."
msgstr "Nome del corriere personalizzato."

msgid "Custom tracking URL."
msgstr "URL di tracciamento personalizzato."

msgid "Tracking number."
msgstr "Numero di tracciamento."

msgid "Shipped date (Y-m-d)."
msgstr "Data di spedizione (A-m-g)."

msgid "Tracking Information"
msgstr "Informazioni di tracciamento"

msgid "Provider"
msgstr "Corriere"

msgid "Tracking Number"
msgstr "Numero di tracciamento"

msgid "Date"
msgstr "Data"

msgid "TRACKING INFORMATION"
msgstr "INFORMAZIONI DI TRACCIAMENTO"

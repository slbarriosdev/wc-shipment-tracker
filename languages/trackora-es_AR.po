msgstr "Courier personalizado"

msgid "Provider Name:"
msgstr "Nombre del courier:"

msgid "Tracking Number:"
msgstr "Número de seguimiento:"

msgid "Tracking Link:"
msgstr "Enlace de seguimiento:"


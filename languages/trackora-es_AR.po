msgstr "Vista previa:"

msgid "Click here to track your shipment"
msgstr "Hacé clic acá para rastrear tu envío"

msgid "Save Tracking"
msgstr "Guardar seguimiento"

msgid "Cancel"
msgstr "Cancelar"

msgid "Are you sure you want to delete this tracking number?"
msgstr "¿Estás seguro de que querés eliminar este número de seguimiento?"

msgid "An error occurred. Please try again."
msgstr "Ocurrió un error. Por favor, intentá de nuevo."

msgid "Please enter a tracking number."
msgstr "Por favor, ingresá un número de seguimiento."

msgid "Search provider…"
msgstr "Buscar courier…"

msgid "Edit Tracking"
msgstr "Editar seguimiento"

msgid "Shipped on %s"
msgstr "Despachado el %s"

msgid "No shipping date"
msgstr "Sin fecha de despacho"

msgid "Track"
msgstr "Rastrear"

msgid "Edit"
msgstr "Editar"

msgid "Delete"
msgstr "Eliminar"

msgid "Tracking number is required."
msgstr "El número de seguimiento es obligatorio."

msgid "Could not update tracking item."
msgstr "No se pudo actualizar el seguimiento."

msgid "Could not delete tracking item."
msgstr "No se pudo eliminar el seguimiento."

msgid "Sorry, you cannot list resources."
msgstr "Lo sentimos, no tenés permiso para listar recursos."

msgid "Sorry, you are not allowed to create resources."
msgstr "Lo sentimos, no tenés permiso para crear recursos."

msgid "Sorry, you cannot view this resource."
msgstr "Lo sentimos, no tenés permiso para ver este recurso."

msgid "Sorry, you are not allowed to delete this resource."
msgstr "Lo sentimos, no tenés permiso para eliminar este recurso."

msgid "Invalid order ID."
msgstr "ID de pedido no válido."

msgid "Invalid tracking ID."
msgstr "ID de seguimiento no válido."

msgid "Cannot create existing tracking item."
msgstr "No se puede crear un seguimiento que ya existe."

msgid "The tracking item cannot be deleted."
msgstr "El seguimiento no se puede eliminar."

msgid "Unique identifier for the tracking item."
msgstr "Identificador único del seguimiento."

msgid "Tracking provider name."
msgstr "Nombre del courier."

msgid "Custom provider name."
msgstr "Nombre del courier personalizado."

msgid "Custom tracking URL."
msgstr "URL de seguimiento personalizada."

msgid "Tracking number."
msgstr "Número de seguimiento."

msgid "Shipped date (Y-m-d)."
msgstr "Fecha de despacho (A-m-d)."

msgid "Tracking Information"
msgstr "Información de seguimiento"

msgid "Provider"
msgstr "Courier"

msgid "Tracking Number"
msgstr "Número de seguimiento"

msgid "Date"
msgstr "Fecha"

msgid "TRACKING INFORMATION"
msgstr "INFORMACIÓN DE SEGUIMIENTO"

msgid "%s stores a shipment tracking number, the carrier name and the shipping date against each order. This information is shown to the customer in order emails, in the My Account area and on any public tracking page, and is exported or erased together with the order it belongs to. No tracking data is sent to any third party by the plugin; tracking links are only opened when a customer or a store administrator clicks them."
msgstr "%s guarda un número de seguimiento, el nombre del correo o courier y la fecha de envío en cada pedido. Esta información se muestra al cliente en los correos del pedido, en el área Mi cuenta y en cualquier página pública de seguimiento, y se exporta o se borra junto con el pedido al que pertenece. El plugin no envía ningún dato de seguimiento a terceros; los enlaces de seguimiento solo se abren cuando el cliente o el administrador de la tienda hacen clic en ellos."

msgid "Billing Email"
msgstr "Correo electrónico de facturación"

msgid "Copy tracking number"
msgstr "Copiar número de seguimiento"

msgid "Date Shipped"
msgstr "Fecha de envío"

msgid "Enter your order number and email address to track your shipment."
msgstr "Ingresá tu número de pedido y tu correo electrónico para rastrear tu envío."

msgid "Insufficient permissions."
msgstr "Permisos insuficientes."

msgid "Invalid order or tracking link. Please check your email and try again."
msgstr "Pedido o enlace de seguimiento no válido. Revisá tu correo e intentá de nuevo."

msgid "No order found with that order number and email address."
msgstr "No se encontró ningún pedido con ese número y esa dirección de correo."

msgid "Order Number"
msgstr "Número de pedido"

msgid "Put %1$s where the tracking number goes, for example %2$s. You can also paste the complete link for this one shipment, with the number already in it. Leave it empty if the carrier has no tracking page."
msgstr "Escribí %1$s donde vaya el número de seguimiento, por ejemplo %2$s. También podés pegar el enlace completo de este envío, con el número ya incluido. Dejalo vacío si el correo no tiene página de seguimiento."

msgid "Removed shipment tracking data from order %s."
msgstr "Se eliminaron los datos de seguimiento del pedido %s."

msgid "Security check failed. Please try again."
msgstr "La verificación de seguridad falló. Intentá de nuevo."

msgid "Sorry, you are not allowed to edit this resource."
msgstr "Lo sentimos, no tenés permiso para editar este recurso."

msgid "The tracking item cannot be updated."
msgstr "No se puede actualizar el envío."

msgid "This link contains neither the tracking number nor a %s token, so the Track button will not track anything."
msgstr "Este enlace no contiene ni el número de seguimiento ni un token %s, así que el botón Rastrear no va a rastrear nada."

msgid "Track Order"
msgstr "Rastrear pedido"

msgid "Track another order"
msgstr "Rastrear otro pedido"

msgid "Tracking Provider"
msgstr "Correo/Courier"

msgid "Tracking information for order %s"
msgstr "Información de seguimiento del pedido %s"

msgid "Trackora"
msgstr "Trackora"

msgid "Trackora Shipment Tracking Data"
msgstr "Datos de seguimiento de envíos de Trackora"

msgid "Your order has no tracking information yet. Please check back later."
msgstr "Tu pedido todavía no tiene información de seguimiento. Volvé a consultarlo más tarde."

msgid "e.g. 1234"
msgstr "p. ej. 1234"

msgid "you@example.com"
msgstr "tu@ejemplo.com"

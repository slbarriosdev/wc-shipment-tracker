msgid "WC Shipment Tracker requires WooCommerce to be installed and active."
msgstr "WC Shipment Tracker nécessite que WooCommerce soit installé et actif."

msgid "Shipment Tracking"
msgstr "Suivi d'expédition"

msgid "Add Tracking Number"
msgstr "Ajouter un numéro de suivi"

msgid "Provider:"
msgstr "Transporteur :"

msgid "Custom Provider"
msgstr "Transporteur personnalisé"

msgid "Provider Name:"
msgstr "Nom du transporteur :"

msgid "Tracking Number:"
msgstr "Numéro de suivi :"

msgid "Tracking Link:"
msgstr "Lien de suivi :"

msgid "Date Shipped:"
msgstr "Date d'expédition :"

msgid "Preview:"
msgstr "Aperçu :"

msgid "Click here to track your shipment"
msgstr "Cliquez ici pour suivre votre colis"

msgid "Save Tracking"
msgstr "Enregistrer le suivi"

msgid "Cancel"
msgstr "Annuler"

msgid "Are you sure you want to delete this tracking number?"
msgstr "Êtes-vous sûr de vouloir supprimer ce numéro de suivi ?"

msgid "An error occurred. Please try again."
msgstr "Une erreur s'est produite. Veuillez réessayer."

msgid "Please enter a tracking number."
msgstr "Veuillez saisir un numéro de suivi."

msgid "Search provider…"
msgstr "Rechercher un transporteur…"

msgid "Edit Tracking"
msgstr "Modifier le suivi"

msgid "Shipped on %s"
msgstr "Expédié le %s"

msgid "No shipping date"
msgstr "Pas de date d'expédition"

msgid "Track"
msgstr "Suivre"

msgid "Edit"
msgstr "Modifier"

msgid "Delete"
msgstr "Supprimer"

msgid "Tracking number is required."
msgstr "Le numéro de suivi est obligatoire."

msgid "Could not update tracking item."
msgstr "Impossible de mettre à jour le suivi."

msgid "Could not delete tracking item."
msgstr "Impossible de supprimer le suivi."

msgid "Sorry, you cannot list resources."
msgstr "Désolé, vous n'êtes pas autorisé à lister les ressources."

msgid "Sorry, you are not allowed to create resources."
msgstr "Désolé, vous n'êtes pas autorisé à créer des ressources."

msgid "Sorry, you cannot view this resource."
msgstr "Désolé, vous n'êtes pas autorisé à voir cette ressource."

msgid "Sorry, you are not allowed to delete this resource."
msgstr "Désolé, vous n'êtes pas autorisé à supprimer cette ressource."

msgid "Invalid order ID."
msgstr "Identifiant de commande invalide."

msgid "Invalid tracking ID."
msgstr "Identifiant de suivi invalide."

msgid "Cannot create existing tracking item."
msgstr "Impossible de créer un suivi qui existe déjà."

msgid "The tracking item cannot be deleted."
msgstr "Le suivi ne peut pas être supprimé."

msgid "Unique identifier for the tracking item."
msgstr "Identifiant unique du suivi."

msgid "Tracking provider name."
msgstr "Nom du transporteur."

msgid "Custom provider name."
msgstr "Nom du transporteur personnalisé."

msgid "Custom tracking URL."
msgstr "URL de suivi personnalisée."

msgid "Tracking number."
msgstr "Numéro de suivi."

msgid "Shipped date (Y-m-d)."
msgstr "Date d'expédition (A-m-j)."

msgid "Tracking Information"
msgstr "Informations de suivi"

msgid "Provider"
msgstr "Transporteur"

msgid "Tracking Number"
msgstr "Numéro de suivi"

msgid "Date"
msgstr "Date"

msgid "TRACKING INFORMATION"
msgstr "INFORMATIONS DE SUIVI"

msgid "%s stores a shipment tracking number, the carrier name and the shipping date against each order. This information is shown to the customer in order emails, in the My Account area and on any public tracking page, and is exported or erased together with the order it belongs to. No tracking data is sent to any third party by the plugin; tracking links are only opened when a customer or a store administrator clicks them."
msgstr "%s enregistre un numéro de suivi, le nom du transporteur et la date d'expédition pour chaque commande. Ces informations sont affichées au client dans les e-mails de commande, dans l'espace Mon compte et sur toute page de suivi publique, et elles sont exportées ou effacées en même temps que la commande à laquelle elles appartiennent. L'extension n'envoie aucune donnée de suivi à des tiers ; les liens de suivi ne s'ouvrent que lorsqu'un client ou un administrateur de la boutique clique dessus."

msgid "Billing Email"
msgstr "E-mail de facturation"

msgid "Copy tracking number"
msgstr "Copier le numéro de suivi"

msgid "Date Shipped"
msgstr "Date d'expédition"

msgid "Enter your order number and email address to track your shipment."
msgstr "Saisissez votre numéro de commande et votre adresse e-mail pour suivre votre colis."

msgid "Insufficient permissions."
msgstr "Permissions insuffisantes."

msgid "Invalid order or tracking link. Please check your email and try again."
msgstr "Commande ou lien de suivi non valide. Vérifiez votre e-mail et réessayez."

msgid "No order found with that order number and email address."
msgstr "Aucune commande trouvée avec ce numéro et cette adresse e-mail."

msgid "Order Number"
msgstr "Numéro de commande"

msgid "Put %1$s where the tracking number goes, for example %2$s. You can also paste the complete link for this one shipment, with the number already in it. Leave it empty if the carrier has no tracking page."
msgstr "Placez %1$s à l'endroit du numéro de suivi, par exemple %2$s. Vous pouvez aussi coller le lien complet de cette expédition, numéro compris. Laissez vide si le transporteur n'a pas de page de suivi."

msgid "Removed shipment tracking data from order %s."
msgstr "Données de suivi supprimées de la commande %s."

msgid "Security check failed. Please try again."
msgstr "La vérification de sécurité a échoué. Veuillez réessayer."

msgid "Sorry, you are not allowed to edit this resource."
msgstr "Désolé, vous n'êtes pas autorisé à modifier cette ressource."

msgid "The tracking item cannot be updated."
msgstr "Impossible de mettre à jour l'expédition."

msgid "This link contains neither the tracking number nor a %s token, so the Track button will not track anything."
msgstr "Ce lien ne contient ni le numéro de suivi ni un jeton %s : le bouton Suivre ne suivra rien."

msgid "Track Order"
msgstr "Suivre la commande"

msgid "Track another order"
msgstr "Suivre une autre commande"

msgid "Tracking Provider"
msgstr "Transporteur"

msgid "Tracking information for order %s"
msgstr "Informations de suivi de la commande %s"

msgid "Trackora"
msgstr "Trackora"

msgid "Trackora Shipment Tracking Data"
msgstr "Données de suivi d'expédition Trackora"

msgid "Your order has no tracking information yet. Please check back later."
msgstr "Votre commande n'a pas encore d'informations de suivi. Revenez plus tard."

msgid "e.g. 1234"
msgstr "ex. 1234"

msgid "you@example.com"
msgstr "vous@exemple.com"

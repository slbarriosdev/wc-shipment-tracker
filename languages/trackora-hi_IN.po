msgid "WC Shipment Tracker requires WooCommerce to be installed and active."
msgstr "WC Shipment Tracker के लिए WooCommerce का इंस्टॉल और सक्रिय होना आवश्यक है।"

msgid "Shipment Tracking"
msgstr "शिपमेंट ट्रैकिंग"

msgid "Add Tracking Number"
msgstr "ट्रैकिंग नंबर जोड़ें"

msgid "Provider:"
msgstr "कूरियर:"

msgid "Custom Provider"
msgstr "कस्टम कूरियर"

msgid "Provider Name:"
msgstr "कूरियर का नाम:"

msgid "Tracking Number:"
msgstr "ट्रैकिंग नंबर:"

msgid "Tracking Link:"
msgstr "ट्रैकिंग लिंक:"

msgid "Date Shipped:"
msgstr "शिपिंग की तारीख:"

msgid "Preview:"
msgstr "पूर्वावलोकन:"

msgid "Click here to track your shipment"
msgstr "अपना शिपमेंट ट्रैक करने के लिए यहाँ क्लिक करें"

msgid "Save Tracking"
msgstr "ट्रैकिंग सहेजें"

msgid "Cancel"
msgstr "रद्द करें"

msgid "Are you sure you want to delete this tracking number?"
msgstr "क्या आप वाकई इस ट्रैकिंग नंबर को हटाना चाहते हैं?"

msgid "An error occurred. Please try again."
msgstr "एक त्रुटि हुई। कृपया पुनः प्रयास करें।"

msgid "Please enter a tracking number."
msgstr "कृपया एक ट्रैकिंग नंबर दर्ज करें।"

msgid "Search provider…"
msgstr "कूरियर खोजें…"

msgid "Edit Tracking"
msgstr "ट्रैकिंग संपादित करें"

msgid "Shipped on %s"
msgstr "%s को भेजा गया"

msgid "No shipping date"
msgstr "कोई शिपिंग तारीख नहीं"

msgid "Track"
msgstr "ट्रैक करें"

msgid "Edit"
msgstr "संपादित करें"

msgid "Delete"
msgstr "हटाएं"

msgid "Tracking number is required."
msgstr "ट्रैकिंग नंबर आवश्यक है।"

msgid "Could not update tracking item."
msgstr "ट्रैकिंग अपडेट नहीं हो सकी।"

msgid "Could not delete tracking item."
msgstr "ट्रैकिंग हटाई नहीं जा सकी।"

msgid "Sorry, you cannot list resources."
msgstr "क्षमा करें, आपके पास संसाधन सूचीबद्ध करने की अनुमति नहीं है।"

msgid "Sorry, you are not allowed to create resources."
msgstr "क्षमा करें, आपके पास संसाधन बनाने की अनुमति नहीं है।"

msgid "Sorry, you cannot view this resource."
msgstr "क्षमा करें, आपके पास यह संसाधन देखने की अनुमति नहीं है।"

msgid "Sorry, you are not allowed to delete this resource."
msgstr "क्षमा करें, आपके पास यह संसाधन हटाने की अनुमति नहीं है।"

msgid "Invalid order ID."
msgstr "अमान्य ऑर्डर आईडी।"

msgid "Invalid tracking ID."
msgstr "अमान्य ट्रैकिंग आईडी।"

msgid "Cannot create existing tracking item."
msgstr "पहले से मौजूद ट्रैकिंग नहीं बनाई जा सकती।"

msgid "The tracking item cannot be deleted."
msgstr "ट्रैकिंग हटाई नहीं जा सकती।"

msgid "Unique identifier for the tracking item."
msgstr "ट्रैकिंग का अद्वितीय पहचानकर्ता।"

msgid "Tracking provider name."
msgstr "कूरियर का नाम।"

msgid "Custom provider name."
msgstr "कस्टम कूरियर का नाम।"

msgid "Custom tracking URL."
msgstr "कस्टम ट्रैकिंग URL।"

msgid "Tracking number."
msgstr "ट्रैकिंग नंबर।"

msgid "Shipped date (Y-m-d)."
msgstr "शिपिंग की तारीख (Y-m-d)।"

msgid "Tracking Information"
msgstr "ट्रैकिंग जानकारी"

msgid "Provider"
msgstr "कूरियर"

msgid "Tracking Number"
msgstr "ट्रैकिंग नंबर"

msgid "Date"
msgstr "तारीख"

msgid "TRACKING INFORMATION"
msgstr "ट्रैकिंग जानकारी"

msgid "%s stores a shipment tracking number, the carrier name and the shipping date against each order. This information is shown to the customer in order emails, in the My Account area and on any public tracking page, and is exported or erased together with the order it belongs to. No tracking data is sent to any third party by the plugin; tracking links are only opened when a customer or a store administrator clicks them."
msgstr "%s हर ऑर्डर के साथ एक ट्रैकिंग नंबर, कूरियर कंपनी का नाम और शिपिंग तिथि सहेजता है। यह जानकारी ग्राहक को ऑर्डर के ईमेल में, मेरा खाता क्षेत्र में और किसी भी सार्वजनिक ट्रैकिंग पेज पर दिखाई जाती है, और जिस ऑर्डर से यह जुड़ी है उसके साथ ही निर्यात या मिटाई जाती है। यह प्लगइन कोई भी ट्रैकिंग डेटा किसी तीसरे पक्ष को नहीं भेजता; ट्रैकिंग लिंक तभी खुलते हैं जब ग्राहक या स्टोर व्यवस्थापक उन पर क्लिक करता है।"

msgid "Billing Email"
msgstr "बिलिंग ईमेल"

msgid "Copy tracking number"
msgstr "ट्रैकिंग नंबर कॉपी करें"

msgid "Date Shipped"
msgstr "शिपिंग तिथि"

msgid "Enter your order number and email address to track your shipment."
msgstr "अपनी शिपमेंट ट्रैक करने के लिए अपना ऑर्डर नंबर और ईमेल पता दर्ज करें।"

msgid "Insufficient permissions."
msgstr "अपर्याप्त अनुमतियाँ।"

msgid "Invalid order or tracking link. Please check your email and try again."
msgstr "अमान्य ऑर्डर या ट्रैकिंग लिंक। कृपया अपना ईमेल जाँचें और फिर से प्रयास करें।"

msgid "No order found with that order number and email address."
msgstr "उस ऑर्डर नंबर और ईमेल पते के साथ कोई ऑर्डर नहीं मिला।"

msgid "Order Number"
msgstr "ऑर्डर नंबर"

msgid "Put %1$s where the tracking number goes, for example %2$s. You can also paste the complete link for this one shipment, with the number already in it. Leave it empty if the carrier has no tracking page."
msgstr "जहाँ ट्रैकिंग नंबर आना है वहाँ %1$s लिखें, उदाहरण के लिए %2$s। आप इस शिपमेंट का पूरा लिंक भी चिपका सकते हैं, जिसमें नंबर पहले से हो। यदि कूरियर कंपनी का कोई ट्रैकिंग पेज नहीं है तो इसे खाली छोड़ दें।"

msgid "Removed shipment tracking data from order %s."
msgstr "ऑर्डर %s से शिपमेंट ट्रैकिंग डेटा हटा दिया गया।"

msgid "Security check failed. Please try again."
msgstr "सुरक्षा जाँच विफल रही। कृपया फिर से प्रयास करें।"

msgid "Sorry, you are not allowed to edit this resource."
msgstr "क्षमा करें, आपको इस संसाधन को संपादित करने की अनुमति नहीं है।"

msgid "The tracking item cannot be updated."
msgstr "शिपमेंट अपडेट नहीं किया जा सका।"

msgid "This link contains neither the tracking number nor a %s token, so the Track button will not track anything."
msgstr "इस लिंक में न तो ट्रैकिंग नंबर है और न ही %s टोकन, इसलिए ट्रैक बटन कुछ भी ट्रैक नहीं करेगा।"

msgid "Track Order"
msgstr "ऑर्डर ट्रैक करें"

msgid "Track another order"
msgstr "दूसरा ऑर्डर ट्रैक करें"

msgid "Tracking Provider"
msgstr "कूरियर कंपनी"

msgid "Tracking information for order %s"
msgstr "ऑर्डर %s की ट्रैकिंग जानकारी"

msgid "Trackora"
msgstr "Trackora"

msgid "Trackora Shipment Tracking Data"
msgstr "Trackora शिपमेंट ट्रैकिंग डेटा"

msgid "Your order has no tracking information yet. Please check back later."
msgstr "आपके ऑर्डर की अभी कोई ट्रैकिंग जानकारी नहीं है। कृपया बाद में देखें।"

msgid "e.g. 1234"
msgstr "उदा. 1234"

msgid "you@example.com"
msgstr "aap@udaharan.com"

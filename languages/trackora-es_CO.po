msgid "WC Shipment Tracker requires WooCommerce to be installed and active."
msgstr "WC Shipment Tracker requiere que WooCommerce esté instalado y activo."

msgid "Shipment Tracking"
msgstr "Seguimiento de envío"

msgid "Add Tracking Number"
msgstr "Agregar número de rastreo"

msgid "Provider:"
msgstr "Transportadora:"

msgid "Custom Provider"
msgstr "Transportadora personalizada"

msgid "Provider Name:"
msgstr "Nombre de la transportadora:"

msgid "Tracking Number:"
msgstr "Número de rastreo:"

msgid "Tracking Link:"
msgstr "Enlace de rastreo:"

msgid "Date Shipped:"
msgstr "Fecha de despacho:"

msgid "Preview:"
msgstr "Vista previa:"

msgid "Click here to track your shipment"
msgstr "Haga clic aquí para rastrear su envío"

msgid "Save Tracking"
msgstr "Guardar rastreo"

msgid "Cancel"
msgstr "Cancelar"

msgid "Are you sure you want to delete this tracking number?"
msgstr "¿Está seguro de que desea eliminar este número de rastreo?"

msgid "An error occurred. Please try again."
msgstr "Ocurrió un error. Por favor, intente de nuevo."

msgid "Please enter a tracking number."
msgstr "Por favor, ingrese un número de rastreo."

msgid "Search provider…"

msgid "No shipping date"
msgstr "Sin fecha de despacho"

msgid "Track"
msgstr "Rastrear"

msgid "Edit"
msgstr "Editar"

msgid "Delete"
msgstr "Eliminar"

msgid "Tracking number is required."
msgstr "El número de rastreo es obligatorio."

msgid "Could not update tracking item."
msgstr "No se pudo actualizar el rastreo."

msgid "Could not delete tracking item."
msgstr "No se pudo eliminar el rastreo."

msgid "Sorry, you cannot list resources."
msgstr "Lo sentimos, no tiene permiso para listar recursos."

msgid "Sorry, you are not allowed to create resources."
msgstr "Lo sentimos, no tiene permiso para crear recursos."

msgid "Sorry, you cannot view this resource."
msgstr "Lo sentimos, no tiene permiso para ver este recurso."

msgid "Sorry, you are not allowed to delete this resource."
msgstr "Lo sentimos, no tiene permiso para eliminar este recurso."

msgid "Invalid order ID."
msgstr "ID de pedido no válido."

msgid "Invalid tracking ID."
msgstr "ID de rastreo no válido."


msgstr "Nombre de la transportadora personalizada."

msgid "Custom tracking URL."
msgstr "URL de rastreo personalizada."

msgid "Tracking number."
msgstr "Número de rastreo."

msgid "Shipped date (Y-m-d)."
msgstr "Fecha de despacho (A-m-d)."

msgid "Tracking Information"
msgstr "Información de rastreo"

msgid "Provider"
msgstr "Transportadora"

msgid "Tracking Number"
msgstr "Número de rastreo"

msgid "Date"
msgstr "Fecha"

msgid "TRACKING INFORMATION"
msgstr "INFORMACIÓN DE RASTREO"

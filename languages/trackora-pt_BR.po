msgid "WC Shipment Tracker requires WooCommerce to be installed and active."
msgstr "WC Shipment Tracker requer que o WooCommerce esteja instalado e ativo."

msgid "Shipment Tracking"
msgstr "Rastreamento de envio"

msgid "Add Tracking Number"
msgstr "Adicionar código de rastreio"

msgid "Provider:"
msgstr "Transportadora:"

msgid "Custom Provider"
msgstr "Transportadora personalizada"

msgid "Provider Name:"
msgstr "Nome da transportadora:"

msgid "Tracking Number:"
msgstr "Código de rastreio:"

msgid "Tracking Link:"
msgstr "Link de rastreamento:"

msgid "Date Shipped:"
msgstr "Data de envio:"

msgid "Preview:"
msgstr "Pré-visualização:"

msgid "Click here to track your shipment"
msgstr "Clique aqui para rastrear seu envio"

msgid "Save Tracking"
msgstr "Salvar rastreamento"

msgid "Cancel"
msgstr "Cancelar"

msgid "Are you sure you want to delete this tracking number?"
msgstr "Tem certeza que deseja excluir este código de rastreio?"

msgid "An error occurred. Please try again."
msgstr "Ocorreu um erro. Por favor, tente novamente."

msgid "Please enter a tracking number."
msgstr "Por favor, insira um código de rastreio."

msgid "Search provider…"
msgstr "Buscar transportadora…"

msgid "Edit Tracking"
msgstr "Editar rastreamento"

msgid "Shipped on %s"
msgstr "Enviado em %s"

msgid "No shipping date"
msgstr "Sem data de envio"

msgid "Track"
msgstr "Rastrear"

msgid "Edit"
msgstr "Editar"

msgid "Delete"
msgstr "Excluir"

msgid "Tracking number is required."
msgstr "O código de rastreio é obrigatório."

msgid "Could not update tracking item."
msgstr "Não foi possível atualizar o rastreamento."

msgid "Could not delete tracking item."
msgstr "Não foi possível excluir o rastreamento."

msgid "Sorry, you cannot list resources."
msgstr "Desculpe, você não tem permissão para listar recursos."

msgid "Sorry, you are not allowed to create resources."
msgstr "Desculpe, você não tem permissão para criar recursos."

msgid "Sorry, you cannot view this resource."
msgstr "Desculpe, você não tem permissão para visualizar este recurso."

msgid "Sorry, you are not allowed to delete this resource."
msgstr "Desculpe, você não tem permissão para excluir este recurso."

msgid "Invalid order ID."
msgstr "ID do pedido inválido."

msgid "Invalid tracking ID."
msgstr "ID de rastreamento inválido."

msgid "Cannot create existing tracking item."
msgstr "Não é possível criar um rastreamento que já existe."

msgid "The tracking item cannot be deleted."
msgstr "O rastreamento não pode ser excluído."

msgid "Unique identifier for the tracking item."
msgstr "Identificador único do rastreamento."

msgid "Tracking provider name."
msgstr "Nome da transportadora."

msgid "Custom provider name."
msgstr "Nome da transportadora personalizada."

msgid "Custom tracking URL."
msgstr "URL de rastreamento personalizada."

msgid "Tracking number."
msgstr "Código de rastreio."

msgid "Shipped date (Y-m-d)."
msgstr "Data de envio (A-m-d)."

msgid "Tracking Information"
msgstr "Informações de rastreamento"

msgid "Provider"
msgstr "Transportadora"

msgid "Tracking Number"
msgstr "Código de rastreio"

msgid "Date"
msgstr "Data"

msgid "TRACKING INFORMATION"
msgstr "INFORMAÇÕES DE RASTREAMENTO"

msgid "%s stores a shipment tracking number, the carrier name and the shipping date against each order. This information is shown to the customer in order emails, in the My Account area and on any public tracking page, and is exported or erased together with the order it belongs to. No tracking data is sent to any third party by the plugin; tracking links are only opened when a customer or a store administrator clicks them."
msgstr "%s armazena um código de rastreio, o nome da transportadora e a data de envio em cada pedido. Essa informação é exibida ao cliente nos e-mails do pedido, na área Minha conta e em qualquer página pública de rastreamento, e é exportada ou apagada junto com o pedido a que pertence. O plugin não envia nenhum dado de rastreamento a terceiros; os links de rastreamento só são abertos quando o cliente ou o administrador da loja clicam neles."

msgid "Billing Email"
msgstr "E-mail de cobrança"

msgid "Copy tracking number"
msgstr "Copiar código de rastreio"

msgid "Date Shipped"
msgstr "Data de envio"

msgid "Enter your order number and email address to track your shipment."
msgstr "Digite o número do seu pedido e o seu e-mail para rastrear o envio."

msgid "Insufficient permissions."
msgstr "Permissões insuficientes."

msgid "Invalid order or tracking link. Please check your email and try again."
msgstr "Pedido ou link de rastreamento inválido. Verifique seu e-mail e tente novamente."

msgid "No order found with that order number and email address."
msgstr "Nenhum pedido encontrado com esse número e esse endereço de e-mail."

msgid "Order Number"
msgstr "Número do pedido"

msgid "Put %1$s where the tracking number goes, for example %2$s. You can also paste the complete link for this one shipment, with the number already in it. Leave it empty if the carrier has no tracking page."
msgstr "Coloque %1$s onde vai o código de rastreio, por exemplo %2$s. Você também pode colar o link completo deste envio, com o código já incluído. Deixe em branco se a transportadora não tiver página de rastreamento."

msgid "Removed shipment tracking data from order %s."
msgstr "Dados de rastreamento removidos do pedido %s."

msgid "Security check failed. Please try again."
msgstr "A verificação de segurança falhou. Tente novamente."

msgid "Sorry, you are not allowed to edit this resource."
msgstr "Desculpe, você não tem permissão para editar este recurso."

msgid "The tracking item cannot be updated."
msgstr "Não foi possível atualizar o envio."

msgid "This link contains neither the tracking number nor a %s token, so the Track button will not track anything."
msgstr "Este link não contém o código de rastreio nem um token %s, então o botão Rastrear não vai rastrear nada."

msgid "Track Order"
msgstr "Rastrear pedido"

msgid "Track another order"
msgstr "Rastrear outro pedido"

msgid "Tracking Provider"
msgstr "Transportadora"

msgid "Tracking information for order %s"
msgstr "Informações de rastreamento do pedido %s"

msgid "Trackora"
msgstr "Trackora"

msgid "Trackora Shipment Tracking Data"
msgstr "Dados de rastreamento de envios do Trackora"

msgid "Your order has no tracking information yet. Please check back later."
msgstr "Seu pedido ainda não tem informações de rastreamento. Volte a consultar mais tarde."

msgid "e.g. 1234"
msgstr "ex.: 1234"

msgid "you@example.com"
msgstr "voce@exemplo.com"
